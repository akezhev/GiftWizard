
{
  "name": "giftwizard-backend",
  "version": "1.0.0",
  "description": "Highload Gift Recommendation API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "cluster": "node cluster.js",
    "prod": "NODE_ENV=production node cluster.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "docker:build": "docker build -t giftwizard-backend .",
    "docker:run": "docker run -p 3000:3000 giftwizard-backend"
  },
  "keywords": ["gift", "recommendation", "ai", "highload"],
  "author": "Timur Akezhev",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  }
}
